# Copy to .env (or just export these) before running.

# Allowlisted root. Every path the tool touches must resolve under this.
LAB_ROOT=/home

# Optional: enables the AI advisor. Tool works fully without it.
# ANTHROPIC_API_KEY=sk-ant-...

# Set to true to disable ALL move/execute endpoints (browse-only).
READ_ONLY=false

# Optional shared-token gate. Unset = no auth (localhost default).
# When set, every request needs HTTP Basic auth: any username, this value as the
# password. /healthz stays open. For real multi-user/network use, prefer a proxy.
# AUTH_TOKEN=change-me-to-a-long-random-string

# Optional network-exposure hardening (both off by default; see README threat model).
# Requests per 60s per client IP; 0 = disabled. In-process only — prefer a proxy.
RATE_LIMIT=0
# When true, the API returns paths relative to LAB_ROOT (hides absolute server paths).
PATH_PRIVACY=false

# Per-directory child cap before the UI shows "+ more".
MAX_CHILDREN=500

# Bind address. Default is localhost-only — see Security in the README.
BIND_HOST=127.0.0.1
BIND_PORT=8000

# Append-only audit log of every executed move.
MOVES_LOG=moves.log
